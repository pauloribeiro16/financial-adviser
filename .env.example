# LLM provider (Anthropic via MiniMax routing)
MINIMAX_API_KEY=sk-ant-...
MINIMAX_MODEL=claude-sonnet-4-5

# Langfuse observability
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Local DuckDB path for assessments
MI_DB_PATH=./data/macro.duckdb

# Runtime mode: dev | test | prod
MFL_ENV=dev